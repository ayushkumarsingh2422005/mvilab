# App
APP_URL=https://mvilab.in
AUTH_SECRET=replace-with-a-long-random-string-at-least-32-characters

# Optional: persistent upload storage outside the deploy folder (absolute path recommended)
# UPLOADS_DIR=/var/lib/mvilab/uploads

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/mvilab

# Brevo transactional email
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@mvilab.in
BREVO_SENDER_NAME=MVI Lab

# First admin seed (npm run seed:admin)
ADMIN_EMAIL=admin@mvilab.in
ADMIN_PASSWORD=change-me-now
ADMIN_NAME=MVI Lab Admin
